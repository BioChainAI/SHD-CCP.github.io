    <!-- Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const state = {
                quaternion: { x: 0.5, y: 0.2, z: 0.3, w: 1.0 },
                structure: 'BC3',
                physics: { spin: 0.0, freq: 1.0, amp: 0.5 },
                s_plane_active: true,
                codex: new Set(), // Set of known pattern hashes
            };

            const plotContainer = document.getElementById('plot-container');
            let cycleInterval;
            
            // --- S-Plane Toggle Logic ---
            const toggle = document.getElementById('s-plane-toggle');
            toggle.addEventListener('change', (e) => {
                state.s_plane_active = e.target.checked;
                // const content = document.getElementById('decoder-content'); // Removed opacity logic
                // const overlay = document.getElementById('decoder-disabled'); // Removed logic
                const scanLine = document.getElementById('scan-line');
                const label = document.querySelector('.toggle-label');
                const statusText = document.getElementById('scan-status');
                const activeText = document.getElementById('scan-state-text');

                if (state.s_plane_active) {
                    scanLine.classList.remove('paused');
                    label.style.backgroundColor = '#10b981'; // Green
                    statusText.innerText = "SCANNING...";
                    statusText.className = "absolute bottom-2 right-2 text-xs font-mono text-emerald-500";
                    activeText.innerText = "ACTIVE";
                    activeText.className = "text-[10px] text-slate-400 font-mono";
                    runScanSimulation();
                } else {
                    scanLine.classList.add('paused');
                    label.style.backgroundColor = '#f59e0b'; // Amber for Paused
                    statusText.innerText = "PAUSED (OPTIMIZING)";
                    statusText.className = "absolute bottom-2 right-2 text-xs font-mono text-amber-500 animate-pulse";
                    activeText.innerText = "PAUSED";
                    activeText.className = "text-[10px] text-amber-500 font-mono";
                }
            });

            function initPlot() {
                const layout = {
                    paper_bgcolor: 'rgba(0,0,0,0)',
                    plot_bgcolor: 'rgba(0,0,0,0)',
                    scene: { xaxis: {visible:false}, yaxis: {visible:false}, zaxis: {visible:false}, camera: {eye: {x:1.5, y:1.5, z:1.5}}, aspectmode: 'cube' },
                    margin: { l: 0, r: 0, b: 0, t: 0 }, showlegend: false
                };
                Plotly.newPlot(plotContainer, generateManifoldData(), layout, {responsive: true, displayModeBar: false});
            }

            function generateManifoldData(step = 0, isCycle = false) {
                const res = 30; // Reduced from 40 for performance
                const x = [], y = [], z = [], x2 = [], y2 = [], z2 = [];
                const twist = state.physics.spin, freq = state.physics.freq, amp = state.physics.amp;
                let R = 3, r = 1;
                
                // Base Manifold Calculation (Simplified loop)
                for (let i = 0; i <= res; i++) {
                    const rowX=[], rowY=[], rowZ=[], rowX2=[], rowY2=[], rowZ2=[];
                    const theta = (i/res)*2*Math.PI;
                    for (let j = 0; j <= res; j++) {
                        const phi = (j/res)*2*Math.PI;
                        let X = (R + r * Math.cos(freq * theta + twist)) * Math.cos(phi);
                        let Y = (R + r * Math.cos(freq * theta + twist)) * Math.sin(phi);
                        let Z = r * Math.sin(freq * theta) * amp * 2;
                        
                        // Quat Rotation
                        const q = state.quaternion;
                        const norm = Math.sqrt(q.x*q.x + q.y*q.y + q.z*q.z + q.w*q.w);
                        const nq = {x:q.x/norm, y:q.y/norm, z:q.z/norm, w:q.w/norm};
                        
                        const ix = nq.w * X + nq.y * Z - nq.z * Y;
                        const iy = nq.w * Y + nq.z * X - nq.x * Z;
                        const iz = nq.w * Z + nq.x * Y - nq.y * X;
                        const iw = -nq.x * X - nq.y * Y - nq.z * Z;

                        X = ix * nq.w + iw * -nq.x + iy * -nq.z - iz * -nq.y;
                        Y = iy * nq.w + iw * -nq.y + iz * -nq.x - ix * -nq.z;
                        Z = iz * nq.w + iw * -nq.z + ix * -nq.y - iy * -nq.x;

                        rowX.push(X); rowY.push(Y); rowZ.push(Z);
                        rowX2.push(X*0.8); rowY2.push(Y*0.8); rowZ2.push(Z*0.8);
                    }
                    x.push(rowX); y.push(rowY); z.push(rowZ);
                    x2.push(rowX2); y2.push(rowY2); z2.push(rowZ2);
                }

                const data = [
                    { type: 'surface', x:x, y:y, z:z, colorscale: 'Viridis', opacity: 0.6, showscale: false },
                    { type: 'surface', x:x2, y:y2, z:z2, colorscale: 'Electric', opacity: 0.2, showscale: false } // Lower opacity
                ];

                if (isCycle) {
                    const numStreams = 12;
                    const streamsX=[], streamsY=[], streamsZ=[];
                    const knotX=[], knotY=[], knotZ=[];
                    const markerColor=[];
                    const progress = step / 720; 
                    
                    // Optimized Stream Logic
                    for(let s = 0; s < numStreams; s++) {
                        const phase = (s / numStreams) * 2 * Math.PI;
                        const theta = progress * 4 * Math.PI + phase;
                        const phi = progress * 6 * Math.PI;
                        
                        let X = (R + r * Math.cos(freq * theta + twist)) * Math.cos(phi);
                        let Y = (R + r * Math.cos(freq * theta + twist)) * Math.sin(phi);
                        let Z = r * Math.sin(freq * theta) * amp * 2;
                        
                        // Quat Rot (Inline for perf)
                        const q = state.quaternion;
                        const norm = Math.sqrt(q.x*q.x + q.y*q.y + q.z*q.z + q.w*q.w);
                        const nq = {x:q.x/norm, y:q.y/norm, z:q.z/norm, w:q.w/norm};
                        
                        const ix = nq.w * X + nq.y * Z - nq.z * Y;
                        const iy = nq.w * Y + nq.z * X - nq.x * Z;
                        const iz = nq.w * Z + nq.x * Y - nq.y * X;
                        const iw = -nq.x * X - nq.y * Y - nq.z * Z;

                        X = ix * nq.w + iw * -nq.x + iy * -nq.z - iz * -nq.y;
                        Y = iy * nq.w + iw * -nq.y + iz * -nq.x - ix * -nq.z;
                        Z = iz * nq.w + iw * -nq.z + ix * -nq.y - iy * -nq.x;

                        streamsX.push(X); streamsY.push(Y); streamsZ.push(Z);
                    }
                    
                    // Optimized Knot Logic: Use pre-calc points for "nodes"
                    const compressionEvents = Math.floor(step / 8);
                    for(let k = 0; k < compressionEvents; k++) {
                        // Position logic similar to stream
                        const eventProgress = (k * 8) / 720;
                        const theta = eventProgress * 4 * Math.PI;
                        const phi = eventProgress * 6 * Math.PI;
                        let cX = (R + r * Math.cos(freq * theta)) * Math.cos(phi);
                        let cY = (R + r * Math.cos(freq * theta)) * Math.sin(phi);
                        let cZ = r * Math.sin(freq * theta) * amp * 2;
                        
                        const q = state.quaternion;
                        const norm = Math.sqrt(q.x*q.x + q.y*q.y + q.z*q.z + q.w*q.w);
                        const nq = {x:q.x/norm, y:q.y/norm, z:q.z/norm, w:q.w/norm};
                        
                        const ix = nq.w * cX + nq.y * cZ - nq.z * cY;
                        const iy = nq.w * cY + nq.z * cX - nq.x * cZ;
                        const iz = nq.w * cZ + nq.x * cY - nq.y * cX;
                        const iw = -nq.x * cX - nq.y * cY - nq.z * cZ;
                        cX = ix * nq.w + iw * -nq.x + iy * -nq.z - iz * -nq.y;
                        cY = iy * nq.w + iw * -nq.y + iz * -nq.x - ix * -nq.z;
                        cZ = iz * nq.w + iw * -nq.z + ix * -nq.y - iy * -nq.x;

                        knotX.push(cX); knotY.push(cY); knotZ.push(cZ);
                        
                        if (k < 22) markerColor.push('#ef4444');
                        else if (k < 45) markerColor.push('#eab308');
                        else if (k < 67) markerColor.push('#10b981');
                        else markerColor.push('#3b82f6');
                    }

                    data.push({ type: 'scatter3d', mode: 'markers', x: streamsX, y: streamsY, z: streamsZ, marker: { size: 4, color: '#ffffff', opacity: 0.9 }, name: 'Data Streams' });
                    data.push({ type: 'scatter3d', mode: 'markers', x: knotX, y: knotY, z: knotZ, marker: { size: 5, color: markerColor, symbol: 'circle-open' }, name: 'Nodes' });
                }
                return data;
            }

            // Sim logic
            function runScanSimulation() {
                if (!state.s_plane_active) return;
                const redundancy = Math.floor(Math.random() * 30) + 20;
                const triplets = Math.floor(Math.random() * 12) + 4;
                document.getElementById('val-triplets').innerText = triplets;
                document.getElementById('val-redundancy').innerText = redundancy + '%';
                
                // Crystallization Check
                // Generate a pseudo-hash based on current params
                const hashInput = `${state.structure}-${state.physics.spin.toFixed(1)}-${state.physics.freq}`;
                // Simple hash code
                let hash = 0; for(let i=0;i<hashInput.length;i++) hash = Math.imul(31, hash) + hashInput.charCodeAt(i) | 0;
                const hexHash = '0x' + Math.abs(hash).toString(16).toUpperCase();
                
                let isKnown = state.codex.has(hexHash);
                if (!isKnown && Math.random() > 0.7) { // 30% chance to "learn" a new pattern
                    state.codex.add(hexHash);
                    addCodexEntry(hexHash, state.structure, "Novel Topology Detected");
                    isKnown = false; // Just learned
                } else if (isKnown) {
                    // Update UI to show it's cached/referenced
                }

                const list = document.getElementById('soliton-list');
                list.innerHTML = '';
                
                if (isKnown) {
                     list.innerHTML = `<div class="p-2 bg-emerald-900/30 border border-emerald-700 rounded text-center">
                        <div class="text-xs text-emerald-400 font-bold">PATTERN CRYSTALLIZED</div>
                        <div class="text-[10px] text-emerald-600 mt-1">Loaded from Codex: ${hexHash}</div>
                     </div>`;
                } else {
                    for(let i=1; i<=9; i++) {
                        const coord = `[${(Math.random()*2-1).toFixed(2)}, ${(Math.random()*2-1).toFixed(2)}, ${(Math.random()*2-1).toFixed(2)}]`;
                        list.innerHTML += `<div class="text-[10px] font-mono text-slate-400 border-b border-slate-800 pb-1"><span class="text-sky-500">SOL-${i.toString().padStart(2,'0')}:</span> ${coord} <span class="text-emerald-500">LOCKED</span></div>`;
                    }
                }
            }
            
            function addCodexEntry(hash, structure, context) {
                const tbody = document.getElementById('codex-list');
                const row = document.createElement('tr');
                row.className = 'codex-item border-b border-slate-800 hover:bg-slate-800/50';
                row.innerHTML = `
                    <td class="p-2 font-mono text-emerald-400">${hash}</td>
                    <td class="p-2">${structure}</td>
                    <td class="p-2 text-slate-400">${context}</td>
                    <td class="p-2"><span class="bg-sky-900 text-sky-300 px-1 rounded text-[10px]">CACHED</span></td>
                `;
                tbody.prepend(row);
                // Keep list short
                if(tbody.children.length > 5) tbody.lastElementChild.remove();
            }
            
            // ... (Rest of input handling same as previous, simplified for brevity) ...
             function updateState() {
                state.quaternion.x = parseFloat(document.getElementById('quat-x').value);
                state.quaternion.y = parseFloat(document.getElementById('quat-y').value);
                state.quaternion.z = parseFloat(document.getElementById('quat-z').value);
                state.quaternion.w = parseFloat(document.getElementById('quat-w').value);
                state.physics.spin = parseFloat(document.getElementById('input-spin').value);
                state.physics.freq = parseFloat(document.getElementById('input-freq').value);
                state.physics.amp = parseFloat(document.getElementById('input-amp').value);
                state.structure = document.getElementById('input-structure').value;
                document.getElementById('val-spin').innerText = state.physics.spin.toFixed(1);
                document.getElementById('val-freq').innerText = state.physics.freq.toFixed(1);
                document.getElementById('val-amp').innerText = state.physics.amp.toFixed(1);
                updateAPIJSON();
            }

            function updateAPIJSON() {
                const payload = {
                    protocol: "SHD-CCP-v1.0",
                    einstein_tile: { id: state.structure, quat: state.quaternion, phys: state.physics },
                    status: state.s_plane_active ? "SCANNING" : "OPTIMIZED_CYCLE"
                };
                document.getElementById('api-payload').innerText = JSON.stringify(payload, null, 2);
            }

            function projectManifold() {
                document.getElementById('loading-overlay').classList.remove('hidden');
                setTimeout(() => {
                    document.getElementById('loading-overlay').classList.add('hidden');
                    Plotly.react(plotContainer, generateManifoldData(), { paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)', scene: { xaxis: {visible:false}, yaxis: {visible:false}, zaxis: {visible:false} }, showlegend: false });
                    renderBitGrid();
                }, 600);
            }

            document.getElementById('btn-cycle').addEventListener('click', () => {
                let step = 0;
                document.getElementById('cycle-status').classList.remove('hidden');
                
                // Auto-disable S-Plane for performance
                toggle.checked = false;
                toggle.dispatchEvent(new Event('change'));

                if(cycleInterval) clearInterval(cycleInterval);
                cycleInterval = setInterval(() => {
                    if(step > 720) { clearInterval(cycleInterval); return; }
                    document.getElementById('step-counter').innerText = step;
                    Plotly.react(plotContainer, generateManifoldData(step, true), { paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)', scene: { xaxis: {visible:false}, yaxis: {visible:false}, zaxis: {visible:false}, camera: {eye: {x:1.5, y:1.5, z:1.5}} }, showlegend: false });
                    step += 12; // Speed up cycle
                }, 50);
            });

            // Init
            function renderBitGrid() {
                 const grid = document.getElementById('visual-bit-grid'); grid.innerHTML = '';
                 for (let r=0; r<8; r++) for (let c=0; c<8; c++) {
                     const bit = document.createElement('div'); bit.className = 'tile-bit';
                     if(r===0) bit.classList.add('halo'); else if(r===7) bit.classList.add('phys'); else if(r>=2&&r<=5) bit.classList.add('core');
                     if(Math.random()>0.5) bit.classList.add('active');
                     grid.appendChild(bit);
                 }
            }
            ['quat-x','quat-y','quat-z','quat-w','input-structure','input-spin','input-freq','input-amp'].forEach(id => document.getElementById(id).addEventListener('input', updateState));
            document.getElementById('btn-project').addEventListener('click', projectManifold);
            document.getElementById('btn-normalize').addEventListener('click', () => {
                 const q = state.quaternion; const l = Math.sqrt(q.x**2+q.y**2+q.z**2+q.w**2);
                 if(l) { document.getElementById('quat-x').value=(q.x/l).toFixed(3); updateState(); }
            });
            const views={'tab-console':'view-console','tab-protocols':'view-protocols','tab-api':'view-api'};
            Object.keys(views).forEach(k => document.getElementById(k).addEventListener('click', () => {
                 document.querySelectorAll('.tab-button').forEach(b=>b.classList.remove('active')); document.getElementById(k).classList.add('active');
                 Object.values(views).forEach(v=>document.getElementById(v).classList.add('hidden')); document.getElementById(views[k]).classList.remove('hidden');
                 if(k==='tab-console') Plotly.relayout(plotContainer, {autosize:true});
            }));

            initPlot(); renderBitGrid(); updateState(); runScanSimulation();
            setInterval(() => { if(state.s_plane_active) runScanSimulation(); }, 5000);
        });
        function copyToClipboard() { navigator.clipboard.writeText(document.getElementById('api-payload').innerText); alert("Copied!"); }
    </script>
</body>
