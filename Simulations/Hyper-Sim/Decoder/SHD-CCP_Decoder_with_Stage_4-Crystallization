    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.plot.ly/plotly-2.32.0.min.js" charset="utf-8"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Application Structure Plan:
         Optimized SHD-CCP Decoder with Stage 4: Crystallization.
         
         UPDATES:
         1. UI Behavior: The "S-Plane Offline" overlay has been removed. Toggling the scanner now simply pauses the visual animation and stops the background calculation loop.
         2. Persistence: When paused, the last calculated data remains visible.
         3. Status Indication: The scanner status text updates to "PAUSED (OPTIMIZING)" when the 720-step cycle is running.
    -->

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f172a; /* slate-900 */
            color: #e2e8f0; /* slate-200 */
        }
        .font-mono {
            font-family: 'JetBrains Mono', monospace;
        }
        
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #1e293b; }
        ::-webkit-scrollbar-thumb { background: #475569; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #64748b; }

        .tab-button { transition: all 0.2s ease-in-out; border-bottom: 2px solid transparent; }
        .tab-button.active { color: #38bdf8; border-bottom-color: #38bdf8; background: rgba(56, 189, 248, 0.1); }
        
        .panel {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 0.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .tile-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 2px; }
        .tile-bit { aspect-ratio: 1; background: #334155; border-radius: 2px; transition: background-color 0.2s; }
        .tile-bit.active { background: #38bdf8; box-shadow: 0 0 4px #38bdf8; }
        .tile-bit.halo { background: #10b981; }
        .tile-bit.core { background: #3b82f6; }
        .tile-bit.phys { background: #f59e0b; }

        .scan-line {
            height: 2px; background: #10b981; box-shadow: 0 0 8px #10b981;
            animation: scan 2s linear infinite;
        }
        /* When paused, we stop the animation but keep it visible (frozen) or hidden if desired. 
           Here we just pause it. */
        .scan-line.paused {
            animation-play-state: paused;
            opacity: 0.5;
        }
        
        @keyframes scan {
            0% { top: 0%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        
        /* Toggle Switch */
        .toggle-checkbox:checked {
            right: 0;
            border-color: #10b981;
        }
        .toggle-checkbox:checked + .toggle-label {
            background-color: #10b981;
        }
        
        /* Codex Items */
        .codex-item {
            animation: fadeIn 0.5s ease-out;
        }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
